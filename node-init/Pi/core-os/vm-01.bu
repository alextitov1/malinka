---
# butane config for a test VM Fedora CoreOS

variant: fcos
version: "1.6.0"


passwd:
  users:
    - name: core
      # Replace with your public SSH key
      ssh_authorized_keys:
        - ssh-rsa  mac
storage:
  disks:
    - device: /dev/vdb
      wipe_table: true
      partitions:
        - label: my_var1
          size_mib: 8192
          type_guid: 0FC63DAF-8483-4772-8E79-3D69D8477DE4
  filesystems:
    - device: /dev/disk/by-label/my_var1
      format: xfs
      label: my__fs_var1
      path: /var
  files:
    - path: /etc/hostname
      mode: 0644
      contents:
        inline: vm-01

